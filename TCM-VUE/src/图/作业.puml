Enrollment }|--|| Order : "对应"
LearningProgress }|--|| Enrollment : "关联"
LearningProgressService ..> LearningProgress : "管理"
EnrollmentService ..> Enrollment : "管理"
PaymentService ..> Order : "处理"
LearningProgressController ..> LearningProgressService : "调用"
