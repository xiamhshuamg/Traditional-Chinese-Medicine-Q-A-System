@startuml
top to bottom direction
skinparam shadowing false
skinparam defaultFontName Microsoft YaHei
skinparam linetype ortho

' Places as circles
circle "i_w" as iw
circle "p12" as p12
circle "p13" as p13
circle "p24" as p24
circle "p35" as p35
circle "o_w" as ow

' Transitions as rectangles
rectangle "t1" as t1
rectangle "t2" as t2
rectangle "t3" as t3
rectangle "t4" as t4
rectangle "t5" as t5

' Arcs
iw --> t1
t1 --> p12
t1 --> p13
p12 --> t2
p13 --> t3
t2 --> p24
t3 --> p35
p24 --> t4
p35 --> t5
t4 --> ow
t5 --> ow
@enduml


@startuml
!theme plain

package "控制器层" {
  class AuthController {
    +login()
    +register()
    +logout()
    +refreshToken()
  }
  
  class UserController {
    +getUserProfile()
    +updateUserProfile()
    +changePassword()
  }
  
  class TeacherVerificationController {
    +submitVerification()
    +getVerificationStatus()
    +reviewVerification()
  }
}

package "服务层" {
  class UserService {
    +createUser()
    +updateUser()
    +deleteUser()
    +findUserById()
    +findByUsername()
  }
  
  class TeacherVerificationService {
    +submitVerification()
    +reviewVerification()
    +getPendingVerifications()
  }
}

package "实体层" {
  class User {
    -Long userId
    -String username
    -String password
    -String email
    -String role
    -String status
    -String realName
    -String phone
    -Date createdTime
    -Date lastLoginTime
  }
  
  class TeacherVerification {
    -Long verificationId
    -Long userId
    -String realName
    -String idNumber
    -String qualificationDocs
    -String status
    -Date submittedTime
    -Date verifiedTime
    -Long verifiedBy
    -String feedback
  }
}

UserService ..> User : "管理"
TeacherVerificationService ..> TeacherVerification : "管理"
AuthController ..> UserService : "调用"
UserController ..> UserService : "调用"
TeacherVerificationController ..> TeacherVerificationService : "调用"
User ||--|| TeacherVerification : "认证关联"
@enduml

@startuml
!theme plain

package "控制器层" {
  class CourseController {
    +createCourse()
    +updateCourse()
    +deleteCourse()
    +getCourseDetails()
    +getTeacherCourses()
  }
  
  class ChapterController {
    +addChapter()
    +updateChapter()
    +deleteChapter()
    +getCourseChapters()
  }
}

package "服务层" {
  class CourseService {
    +createCourse()
    +updateCourse()
    +submitForReview()
    +publishCourse()
  }
  
  class ChapterService {
    +addChapter()
    +updateChapterOrder()
    +validateChapterAccess()
  }
  
  class CourseAuditService {
    +auditCourse()
    +approveCourse()
    +rejectCourse()
  }
}

package "实体层" {
  class Course {
    -Long courseId
    -String courseName
    -String description
    -BigDecimal price
    -String category
    -Long teacherId
    -String status
    -Date createdTime
    -Date updatedTime
    -Date approvedTime
    -Long approvedBy
  }
  
  class Chapter {
    -Long chapterId
    -Long courseId
    -String chapterName
    -Integer chapterOrder
    -String description
  }
  
  class Resource {
    -Long resourceId
    -Long chapterId
    -String resourceName
    -String resourceType
    -String filePath
    -Long fileSize
    -Integer duration
    -Date uploadTime
  }
}

Course ||--o{ Chapter : "包含"
Chapter ||--o{ Resource : "拥有"
CourseService ..> Course : "管理"
ChapterService ..> Chapter : "管理"
CourseAuditService ..> Course : "审核"
CourseController ..> CourseService : "调用"
ChapterController ..> ChapterService : "调用"
@enduml


@startuml
!theme plain

